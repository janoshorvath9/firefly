# Supabase — Project Settings → API in https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy anon key (optional if publishable key is set)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PREMIUM_SUBSCRIPTION_PRICE_ID=

# Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=Firefly <noreply@firefly.app>
# Plain address for Supabase Auth SMTP (extract from RESEND_FROM_EMAIL)
RESEND_SMTP_ADMIN_EMAIL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron (Vercel)
CRON_SECRET=
